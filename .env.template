# Copy to .env and fill in. .env is gitignored.

# Postgres (matches docker-compose.yml defaults; override for prod)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=beacon
POSTGRES_PASSWORD=beacon
POSTGRES_DB=beacon

# News ingest
NEWSAPI_KEY=

# Ground truth
NASA_FIRMS_KEY=

# Hugging Face Inference (free tier) — used for NER + zero-shot text classification
HF_TOKEN=

# Optional: cap Claude calls per pipeline run during development
BEACON_CLAUDE_CALL_BUDGET=50

# ACLED conflict-event ground truth (free myACLED account at acleddata.com)
# Username/password used only for initial OAuth login; tokens persist in
# .acled_tokens.json (gitignored). Run: `uv run beacon acled-login`.
ACLED_USERNAME=
ACLED_PASSWORD=

# LangSmith tracing (free tier at smith.langchain.com).
# Setting LANGSMITH_TRACING=true auto-streams every LangGraph node call to
# the LangSmith project for per-node latency, errors, and inputs/outputs.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=beacon
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
